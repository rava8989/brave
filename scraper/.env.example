SCHWAB_APP_KEY=YOUR_APP_KEY_HERE
SCHWAB_APP_SECRET=YOUR_APP_SECRET_HERE
SCHWAB_REDIRECT_URI=https://rava8989.github.io/brave/live.html

# Preferred: route Schwab token refresh through the Cloudflare Worker so this
# scraper, the Worker cron, and the browser don't race to rotate the single-
# use refresh_token. When both are set, tokens.json + SCHWAB_APP_KEY/SECRET
# aren't needed for runtime — the browser seeds KV once, Worker owns refresh.
SCHWAB_PROXY_URL=https://schwab-proxy.ravamt4.workers.dev
SCHWAB_SYNC_SECRET=YOUR_WORKER_SYNC_SECRET

# Discord channel ID to monitor (right-click channel → Copy Channel ID)
DISCORD_CHANNEL_ID=YOUR_CHANNEL_ID

# Full path to your local git repo clone
REPO_PATH=C:\Users\YourName\brave

# GitHub personal access token (for pushing JSON files)
GITHUB_TOKEN=YOUR_GITHUB_TOKEN
