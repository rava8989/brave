# Only track frontend files for GitHub Pages
# Everything else stays local
.claude/
.wrangler/
data/
*.py
*.log
*.toml
engine.py
server.py
downloader.py
schwab-proxy.js
requirements.txt
CLAUDE.md

# Scraper — secrets and local cache (NEVER commit these)
scraper/.env
scraper/tokens.json
scraper/data/
scraper/__pycache__/

# Polygon API credentials — NEVER commit
.env
polygon.env
*.env

# Allow scraper Python source files (no secrets in them)
!scraper/*.py
!scraper/requirements.txt

# Allow the precomputed diagonal backtester datasets (browser fetches them)
!data/diagonal_bs_data.json
!data/diagonal_real_data.json
!data/diagonal_real_index.json
!data/diagonal_real_2023.json
!data/diagonal_real_2024.json
!data/diagonal_real_2025.json
!data/diagonal_real_2026.json
# Allow the UOA earnings backtester datasets (browser fetches them)
!data/earnings_uoa_index.json
!data/earnings_uoa_2023.json
!data/earnings_uoa_2024.json
!data/earnings_uoa_2025.json
!data/earnings_uoa_2026.json
!data/earnings_calendar.json
!data/sp500_constituents.json
# Allow the build scripts so the datasets can be regenerated
!build_diagonal_data.py
!build_diagonal_real_data.py
!fetch_polygon_spx.py
!build_earnings_universe.py
!build_earnings_uoa_data.py
# Allow shared signal engine module (loaded by browser + worker)
!signal-engine.js
