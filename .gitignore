# Only track frontend files for GitHub Pages
# Everything else stays local
.claude/
.wrangler/
# data/ layout:
#   data/polygon/, data/spx/, data/vix/ — big raw market data, NOT tracked
#   data/*.csv, data/*.tmp — scratch files, NOT tracked
#   Everything else in data/ is tracked by default (browser-consumable datasets).
# (Blanket-ignoring data/ breaks negation patterns on new files — git's
#  performance optimization skips contents of excluded parent directories.)
data/polygon/
data/spx/
data/vix/
data/qqq/
data/rut/
data/equity_history/
data/*.csv
data/*.tmp
*.py
*.log
*.toml
engine.py
server.py
downloader.py
schwab-proxy.js
requirements.txt
CLAUDE.md

# Polygon API credentials — NEVER commit
.env
polygon.env
*.env

# Allow the precomputed diagonal backtester datasets (browser fetches them)
!data/diagonal_bs_data.json
!data/diagonal_real_index.json
# Half-day SPX closes (8 dates in 2023-2025 — day before July 4th, day after
# Thanksgiving, Christmas Eve). Used for exact intrinsic settlement when a
# diagonal's short leg expires on one of these days and closeDate rolls
# across a holiday (so the short ticker is gone from next-day quotes).
!data/spx_halfday_close.json
# Multi-timestamp per-half-year files are gzipped (each ~40 MB, well under
# GitHub's 100 MB cap; split in half so decompressed JSON stays under V8's
# ~512 MB max string length).
!data/diagonal_real_*.json.gz
# Allow the UOA earnings backtester datasets (browser fetches them)
!data/earnings_uoa_index.json
!data/earnings_uoa_2023.json
!data/earnings_uoa_2024.json
!data/earnings_uoa_2025.json
!data/earnings_uoa_2026.json
!data/earnings_calendar.json
!data/sp500_constituents.json
# Allow the build scripts so the datasets can be regenerated
!build_diagonal_data.py
!build_diagonal_real_data.py
!fetch_polygon_spx.py
!build_earnings_universe.py
!build_earnings_uoa_data.py
# Allow shared signal engine module (loaded by browser + worker)
!signal-engine.js
