# Only track frontend files for GitHub Pages
# Everything else stays local
.claude/
.wrangler/
data/
*.py
*.log
*.toml
engine.py
server.py
downloader.py
schwab-proxy.js
requirements.txt
CLAUDE.md

# Scraper — secrets and local cache (NEVER commit these)
scraper/.env
scraper/tokens.json
scraper/data/
scraper/__pycache__/

# Allow scraper Python source files (no secrets in them)
!scraper/*.py
!scraper/requirements.txt

# Allow the precomputed diagonal backtester dataset (browser fetches it)
!data/diagonal_bs_data.json
# Allow the build script so the dataset can be regenerated
!build_diagonal_data.py
